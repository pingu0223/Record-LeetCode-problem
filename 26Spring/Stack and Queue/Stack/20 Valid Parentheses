class Solution {
public:
    bool isValid(string s) {
        stack<char> a;
        int i;
        for(i=0;i<s.size();i++){
            char item=s[i];
            if(item=='{'||item=='('||item=='['){
                a.push(item);
                continue;
            }
            else{if(a.empty())return false;}
            if(item=='}'){
                char it=a.top();
                a.pop();
                if(it!='{') return false;
            }
            else if(item==')'){
                char it=a.top();
                a.pop();
                if(it!='(') return false;
            }
            else if(item==']'){
                char it=a.top();
                a.pop();
                if(it!='[') return false;
            }
        }
         if(a.empty()) return true;
            return false;
    }
};
