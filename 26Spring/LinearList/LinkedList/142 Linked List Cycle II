///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
class Solution {
public:
    ListNode *detectCycle(ListNode *head) {
     ListNode* p=head;
     unordered_set<ListNode*> list;
     while(p!=nullptr){
        list.insert(p);
        p=p->next;
        if(list.count(p)) return p;
     }   
     return nullptr;
    }
};
