class Solution {
public:
    ListNode* removeNthFromEnd(ListNode* head, int n) {
        int i;
        ListNode* prev=head;
        ListNode* curr=head;
        for(i=0;i<n-1;i++){
            prev=prev->next;
        }
        //分析一下需要修改head的特殊情况
        if(prev->next==nullptr) {
            ListNode* temp=head;
            head=head->next;
            delete temp;
            return head;
        } 
        while(prev->next->next!=nullptr){
            prev=prev->next;
            curr=curr->next;
        }
        ListNode *temp=curr->next;
        curr->next=curr->next->next;
        delete temp;
        return head;

    }
};
