class Solution {
public:
    ListNode* reverseKGroup(ListNode* head, int k) {
    if(k==1) return head;
     ListNode* dummy=new ListNode{0}; 
     dummy->next=head;
     head=dummy;
     int i;
     ListNode* pre=head;
     ListNode* after=nullptr;
     ListNode* start=head->next;
     while(true){
        ListNode* pos=pre;
        for(i=0;i<k;i++){
            pos=pos->next;
            if(pos==nullptr) return head->next;
        }
        after=pos->next;
        ListNode* prev=pre->next;
        ListNode* curr=prev->next;
        while(curr!=after){
            ListNode* temp=curr->next;
            curr->next=prev;
            prev=curr;
            curr=temp;
        }
        pre->next=prev;
        start->next=after;
        pre=start;
        start=after;
     }
     return head->next;

    }
};
