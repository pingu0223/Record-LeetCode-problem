class Solution {
public:
    ListNode* reverseList(ListNode* head) {
        if(head==nullptr||head->next==nullptr) return head;
        ListNode* pos=head;
        ListNode* p=head->next;
        while(p!=nullptr){
            ListNode* temp=p->next;
            p->next=pos;
            pos=p;
            p=temp;
        }
        head->next=nullptr; //别忘记哦！！！！！！！！！！！！！！！！！要把head置空
        head=pos;  
        return head;
    }
};
