class Solution {
public: 
    ListNode *getIntersectionNode(ListNode *headA, ListNode *headB) {
       unordered_map<ListNode*,int>list{0};
       ListNode* pos=headA;
       while(pos!=nullptr){
        list[pos]=pos->val;
        pos=pos->next;
    }
    pos=headB;
    while(pos!=nullptr){
        if(list[pos]!=0) return pos;
        pos=pos->next;
    }
    return nullptr;

    }
};
